# Dodo Payment Integration — Required Environment Variables
# Copy to .env.local and fill in the values

# ── Dodo Payments ──────────────────────────────────────────────────────────────
DODO_API_KEY=sk_live_...
DODO_WEBHOOK_SECRET=whsec_...

# Dodo product price IDs (from Dodo dashboard → Products → Prices)
DODO_PRICE_ID_STARTER=price_...
DODO_PRICE_ID_GROWTH=price_...
DODO_PRICE_ID_SCALE=price_...

# ── App ────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# ── Admin Panel ────────────────────────────────────────────────────────────────
# Comma-separated Clerk user IDs who can access /admin/pricing and PATCH pricing plans
# Leave empty to allow any authenticated user (not recommended for production)
ADMIN_USER_IDS=user_abc123,user_def456

# ── Already in your .env.local (confirm these are set) ────────────────────────
# RESEND_API_KEY=re_...
# REPLY_FROM_EMAIL=support@yourdomain.com
# REPLY_FROM_NAME=Your Company
# SLACK_SIGNING_SECRET=...
# MONGODB_URI=mongodb+srv://...
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_...
# CLERK_SECRET_KEY=sk_...
